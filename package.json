{
  "name": "botcord",
  "version": "0.3.4",
  "private": true,
  "description": "Desktop admin cockpit for Discord (BYOB).",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest": "npm rebuild better-sqlite3 --silent",
    "posttest": "electron-rebuild -f -w better-sqlite3 --silent",
    "lint": "eslint . --ext .ts,.tsx",
    "postinstall": "electron-rebuild -f -w better-sqlite3 && cd node_modules/@discordjs/opus && node ../node-pre-gyp/bin/node-pre-gyp install --fallback-to-build --runtime=electron --target=33.4.11 --target_arch=x64 --dist-url=https://electronjs.org/headers",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux AppImage",
    "dist:win": "npm run build && electron-builder --win nsis",
    "dist:mac": "npm run build && electron-builder --mac dmg zip"
  },
  "build": {
    "appId": "com.botcord.app",
    "productName": "BotCord",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      }
    ],
    "linux": {
      "target": "AppImage",
      "category": "Network",
      "icon": "public/botcord-icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "public/botcord-icon.png"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.social-networking",
      "icon": "public/botcord-icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "publish": {
      "provider": "github",
      "owner": "darkharasho",
      "repo": "BotCord"
    },
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "node_modules/@discordjs/opus/**/*",
      "node_modules/prism-media/**/*"
    ]
  },
  "dependencies": {
    "@claude-cdk/core": "^0.1.0",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-query": "^5.59.0",
    "@types/react-window": "^1.8.8",
    "better-sqlite3": "^11.3.0",
    "discord.js": "^14.16.3",
    "electron-updater": "^6.8.3",
    "libsodium-wrappers": "^0.8.4",
    "prism-media": "^1.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "react-window": "^2.2.7",
    "unicode-emoji-json": "^0.9.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.0",
    "node-gyp": "^12.3.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
